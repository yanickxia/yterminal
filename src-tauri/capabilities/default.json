{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default capability for yterminal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "os:default",
    "updater:default",
    "process:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" }
      ]
    }
  ]
}
